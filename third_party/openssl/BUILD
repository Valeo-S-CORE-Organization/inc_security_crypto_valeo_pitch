load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name = "openssl_make",
    args = ["-j8"],
    configure_command = "Configure",
    configure_in_place = False,
    configure_options = [
        "no-shared",
        "no-asm",
        "no-threads",
        "no-makedepend",
        "no-sock",
        "no-apps",
        "no-tests",
        "no-docs",
        "no-ui-console",
        "no-ssl3",
        "no-tls1",
        "no-tls1_1",
        "no-dtls",
        "no-srtp",
        "no-cms",
        "no-ct",
        "no-srp",
        "no-ocsp",
        "no-psk",
        "no-nextprotoneg",
        "no-comp",
        "no-md2",
        "no-md4",
        "no-mdc2",
        "no-rc2",
        "no-rc4",
        "no-rc5",
        "no-idea",
        "no-seed",
        "no-cast",
        "no-bf",
        "no-camellia",
        "no-aria",
        "no-whirlpool",
        "no-sm2",
        "no-sm3",
        "no-sm4",
        "no-gost",
        "no-afalgeng",
        "no-padlockeng",
        "no-legacy",
        "no-async",
        "no-dso",
        "-DUSE_TIMEGM",
        "--prefix=$$INSTALLDIR",
        "--openssldir=$$INSTALLDIR",
        "--libdir=lib",
    ] + select({
        "@score_bazel_platforms//settings:aarch64-qnx": ["linux-aarch64"],
        "@score_bazel_platforms//settings:x86_64-qnx": ["linux-x86_64"],
        "@score_bazel_platforms//settings:aarch64-linux": ["linux-aarch64"],
        "@score_bazel_platforms//settings:x86_64-linux": ["linux-x86_64"],
        "//conditions:default": [],
    }),
    env = select({
        "@score_bazel_platforms//settings:aarch64-qnx": {
            "QNX_HOST": "$$PWD/external/score_bazel_cpp_toolchains++gcc+score_qcc_aarch64_toolchain_pkg/host/linux/x86_64",
            "QNX_TARGET": "$$PWD/external/score_bazel_cpp_toolchains++gcc+score_qcc_aarch64_toolchain_pkg/target/qnx",
        },
        "@score_bazel_platforms//settings:x86_64-qnx": {
            "QNX_HOST": "$$PWD/external/score_bazel_cpp_toolchains++gcc+score_qcc_x86_64_toolchain_pkg/host/linux/x86_64",
            "QNX_TARGET": "$$PWD/external/score_bazel_cpp_toolchains++gcc+score_qcc_x86_64_toolchain_pkg/target/qnx",
        },
        "//conditions:default": {},
    }),
    lib_source = "@openssl_source//:all",
    out_lib_dir = "lib",
    out_static_libs = [
        "libssl.a",
        "libcrypto.a",
    ],
    tags = ["no-sandbox"],
    targets = [
        "build_libs",
        "install_dev",
    ],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "openssl",
    visibility = ["//visibility:public"],
    deps = [":openssl_make"],
)
